{
  "name": "n8n-nodes-rentman",
  "version": "26.1.9-1.9.0",
  "description": "n8n community node for Rentman — the rental management software for AV, event, and crewing companies",
  "keywords": [
    "n8n-community-node-package",
    "rentman",
    "rental",
    "equipment-rental",
    "rental-management",
    "av-rental",
    "event-rental",
    "staging",
    "crm",
    "n8n"
  ],
  "license": "MIT",
  "homepage": "https://github.com/huelsevoort/n8n-nodes-rentman",
  "author": {
    "name": "Maurice Huelsevoort",
    "email": "maurice@huelse.cc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/huelsevoort/n8n-nodes-rentman.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint --ext .ts nodes credentials",
    "lint:fix": "eslint --ext .ts --fix nodes credentials",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RentmanApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Rentman/Rentman.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^5.0.1",
    "prettier": "^3.3.2",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
